# IntelliJ IDEA 配置文件
.idea/
*.iml
*.iws
*.ipr

# 编译输出目录（Java 项目的 class 文件、可执行文件）
out/
target/
build/

# 操作系统自动生成的文件
.DS_Store  # Mac 系统
Thumbs.db  # Windows 系统

# 日志文件
*.log

# 临时文件
*.tmp
*.swp

# ========== Visual Studio / C 语言项目 ==========
# 用户配置文件（不提交）
**/*.suo
**/*.vcxproj.user
**/*.vcxproj.filters

# VS 缓存目录
**/.vs/
**/ipch/

# 编译输出目录（所有子文件夹）
**/x64/
**/x86/
**/Debug/
**/Release/

# 编译生成的文件
**/*.obj
**/*.exe
**/*.pdb
**/*.ilk
**/*.tlog
**/*.lastbuildstate
**/*.idb
**/*.pch

# 其他无用文件
nul